# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Secrets
.env

# Music & extracted data — never commit to GitHub
# Folders are kept (via .gitkeep) so cloned repos have the full structure ready
data/raw/*
data/cortinas/*
data/processed/*
data/catalog.csv
data/chroma_store/*
data/domain_knowledge/*

# Keep .gitkeep files so empty folders are tracked
!data/raw/.gitkeep
!data/cortinas/.gitkeep
!data/processed/.gitkeep
!data/processed/todotango_enriched.csv
!data/chroma_store/.gitkeep
!data/domain_knowledge/.gitkeep

# Keep the samples folder fully tracked (5 demo tracks for README onboarding)
!data/samples/

# UI screenshots — local dev only, not needed on GitHub
atdj/ui/screenshots/
*.png

# Playwright MCP console logs — local dev only
.playwright-mcp/

# Claude Code local settings (machine-specific permissions)
.claude/settings.local.json

# AudioSep for exploration
vendor/AudioSep

# Don't track ai_usage for now
doc/ai_usage.md